generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Provider {
  kakao
  google
}

enum AnswerStyle {
  story
  reason
}

model User {
  id            Int            @id @default(autoincrement())
  socialId      String
  provider      Provider
  nickname      String?        @db.VarChar(8)
  profileImage  String?
  answerStyle   AnswerStyle    @default(story)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshTokens RefreshToken[]

  @@unique([socialId, provider])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}
